                    Layout.preferredHeight: 14
                }
            }
        }

        // Keep preview open if mouse enters the popup itself
        MouseArea {
            anchors.fill: parent
            hoverEnabled: true
            onEntered: wsPreviewHideTimer.stop()
            onExited: wsPreviewHideTimer.restart()
        }
